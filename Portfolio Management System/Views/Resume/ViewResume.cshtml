@model ResumeViewModel
@{
    ViewData["Title"] = "Download Resume";
    Layout = "_Layout";
}

<style>
    .resume-card {
        max-width: 600px;
        margin: 50px auto;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        animation: slideUp 0.5s ease;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .resume-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 40px;
        text-align: center;
    }

        .resume-header i {
            font-size: 4rem;
            margin-bottom: 15px;
            animation: bounce 2s infinite;
        }

    @@keyframes bounce {
        0%, 20%, 50%, 80%, 100% {
            transform: translateY(0);
        }

        40% {
            transform: translateY(-20px);
        }

        60% {
            transform: translateY(-10px);
        }
    }

    .resume-body {
        padding: 40px;
        background: white;
    }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
            display: block;
        }

    .form-control {
        border-radius: 12px;
        border: 2px solid #e0e0e0;
        padding: 12px 15px;
        width: 100%;
        font-size: 1rem;
        transition: all 0.3s;
    }

        .form-control:focus {
            border-color: #667eea;
            outline: none;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
        }

    .btn-download {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 15px;
        font-weight: 600;
        font-size: 1.1rem;
        width: 100%;
        cursor: pointer;
        transition: all 0.3s;
    }

        .btn-download:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102,126,234,0.3);
        }

        .btn-download:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

    .info-text {
        font-size: 0.9rem;
        color: #6c757d;
        margin-top: 20px;
        text-align: center;
    }

        .info-text i {
            color: #667eea;
            margin-right: 5px;
        }

    .alert-danger {
        background: #fee;
        color: #c33;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 25px;
    }
</style>

<div class="container">
    <div class="resume-card">
        <div class="resume-header">
            <i class="fas fa-file-pdf"></i>
            <h2 class="h3 mb-2">Download Resume</h2>
            <p class="mb-0 opacity-75">Please provide your details</p>
        </div>

        <div class="resume-body">
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p class="mb-0">@error.ErrorMessage</p>
                    }
                </div>
            }

            <form asp-action="ViewResume" method="post" id="resumeForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="Country" name="Country" value="" />
                <input type="hidden" id="City" name="City" value="" />

                <div class="form-group">
                    <label asp-for="VisitorName">Your Name *</label>
                    <input asp-for="VisitorName" class="form-control" placeholder="Enter your full name" required />
                </div>

                <div class="form-group">
                    <label asp-for="VisitorEmail">Your Email *</label>
                    <input asp-for="VisitorEmail" type="email" class="form-control" placeholder="Enter your email" required />
                </div>

                <div class="form-group">
                    <label asp-for="CompanyName">Company Name (Optional)</label>
                    <input asp-for="CompanyName" class="form-control" placeholder="Where do you work?" />
                </div>

                <div class="form-group">
                    <label asp-for="Designation">Designation (Optional)</label>
                    <input asp-for="Designation" class="form-control" placeholder="Your job title" />
                </div>

                <button type="submit" class="btn-download" id="submitBtn">
                    <span class="spinner-border spinner-border-sm d-none" role="status"></span>
                    <span class="btn-text">Download Resume <i class="fas fa-download ms-2"></i></span>
                </button>

                <div class="info-text">
                    <i class="fas fa-shield-alt"></i> Your information is secure
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            console.log("✅ Resume page loaded");

            $.ajax({
                url: '/Resume/GetUserLocation',
                type: 'GET',
                success: function(data) {
                    console.log("Location:", data);
                    if (data.country) $('#Country').val(data.country);
                    if (data.city) $('#City').val(data.city);
                },
                error: function() {
                    console.log("Could not get location");
                }
            });

            $('#resumeForm').on('submit', function(e) {
                var name = $('#VisitorName').val().trim();
                var email = $('#VisitorEmail').val().trim();

                if (!name) {
                    e.preventDefault();
                    alert('Please enter your name');
                    return;
                }

                if (!email) {
                    e.preventDefault();
                    alert('Please enter your email');
                    return;
                }

                if (!email.includes('@@') || !email.includes('.')) {
                    e.preventDefault();
                    alert('Please enter a valid email (e.g., name@example.com)');
                    return;
                }

                var btn = $('#submitBtn');
                btn.prop('disabled', true);
                btn.find('.spinner-border').removeClass('d-none');
                btn.find('.btn-text').text('Preparing Download...');
            });
        });
    </script>
}