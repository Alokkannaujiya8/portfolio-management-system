@{
    var isAdmin = Context.Session.GetString("Admin") != null;
}

<!-- Chat Widget Styles -->
<style>
    .chat-widget {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 9999;
    }

    .chat-button {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0 5px 20px rgba(102,126,234,0.4);
        transition: transform 0.3s;
    }

        .chat-button:hover {
            transform: scale(1.1);
        }

    .chat-box {
        position: absolute;
        bottom: 80px;
        right: 0;
        width: 350px;
        height: 500px;
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        display: none;
        flex-direction: column;
        overflow: hidden;
    }

        .chat-box.active {
            display: flex;
        }

    .chat-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        background: #f8f9fa;
    }

    .message {
        margin-bottom: 15px;
        max-width: 80%;
    }

        .message.sent {
            margin-left: auto;
        }

        .message.received {
            margin-right: auto;
        }

    .message-content {
        padding: 10px 15px;
        border-radius: 18px;
        font-size: 14px;
    }

    .sent .message-content {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .received .message-content {
        background: white;
        color: #333;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .message-time {
        font-size: 11px;
        color: #6c757d;
        margin-top: 5px;
        text-align: right;
    }

    .chat-input-area {
        padding: 15px;
        background: white;
        border-top: 1px solid #dee2e6;
    }

    .chat-input {
        display: flex;
        gap: 10px;
    }

        .chat-input input {
            flex: 1;
            border: 1px solid #dee2e6;
            border-radius: 25px;
            padding: 10px 15px;
            outline: none;
        }

        .chat-input button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 50%;
            width: 45px;
            height: 45px;
            cursor: pointer;
        }

    .unread-badge {
        position: absolute;
        top: -5px;
        right: -5px;
        background: #dc3545;
        color: white;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        font-size: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        display: none;
    }
</style>

<!-- Chat Widget HTML -->
<div class="chat-widget">
    <div class="chat-box" id="chatBox">
        <div class="chat-header">
            <h6 class="mb-0"><i class="fas fa-comment me-2"></i>Live Chat</h6>
            <button class="btn text-white p-0" onclick="toggleChat()"><i class="fas fa-times"></i></button>
        </div>

        @if (!isAdmin)
        {
            <!-- User Info Form -->
            <div id="userInfoForm" class="p-3">
                <p class="text-muted small mb-3">Please enter your details to start chatting</p>
                <input type="text" id="userName" class="form-control mb-2" placeholder="Your Name">
                <input type="email" id="userEmail" class="form-control mb-2" placeholder="Your Email">
                <button class="btn btn-primary w-100" onclick="startChat()">Start Chat</button>
            </div>
        }

        <!-- Chat Messages Area -->
        <div id="chatMessages" style="display: none;" class="flex-grow-1 d-flex flex-column">
            <div class="bg-light p-2 text-center small" id="onlineStatus">
                <i class="fas fa-circle text-success me-1"></i> <span id="onlineCount">0</span> online
            </div>
            <div class="chat-messages" id="messageList"></div>
            <div class="chat-input-area">
                <div class="chat-input">
                    <input type="text" id="messageInput" placeholder="Type your message..." onkeypress="handleKeyPress(event)">
                    <button onclick="sendMessage()"><i class="fas fa-paper-plane"></i></button>
                </div>
            </div>
        </div>
    </div>

    <button class="chat-button" onclick="toggleChat()" id="chatButton">
        <i class="fas fa-comment"></i>
        <span class="unread-badge" id="unreadBadge">0</span>
    </button>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chathub")
        .build();

    let userName = '';
    let isAdmin = @isAdmin.ToString().ToLower();

    connection.on("ReceiveMessage", function(user, message, time) {
        addMessage(user, message, time, user === userName);
    });

    connection.on("UserJoined", function(user) {
        addSystemMessage(`${user} joined the chat`);
    });

    connection.on("UserLeft", function(user) {
        addSystemMessage(`${user} left the chat`);
    });

    connection.on("UpdateUserCount", function(count) {
        $('#onlineCount').text(count);
    });

    connection.start().catch(err => console.error(err));

    function toggleChat() {
        $('#chatBox').toggleClass('active');
    }

    function startChat() {
        userName = $('#userName').val();
        if (!userName) {
            alert('Please enter your name');
            return;
        }

        $('#userInfoForm').hide();
        $('#chatMessages').show();
        connection.invoke("JoinChat", userName);
    }

    function sendMessage() {
        var message = $('#messageInput').val();
        if (!message) return;

        connection.invoke("SendMessage", userName, message);
        $('#messageInput').val('');
    }

    function addMessage(user, message, time, isSent) {
        var messageDiv = $('<div>').addClass('message').addClass(isSent ? 'sent' : 'received');
        messageDiv.html(`
            <div class="message-content">${message}</div>
            <div class="message-time">${time}</div>
        `);
        $('#messageList').append(messageDiv);
        $('#messageList').scrollTop($('#messageList')[0].scrollHeight);
    }

    function addSystemMessage(text) {
        $('#messageList').append(`<div class="text-center text-muted small my-2">${text}</div>`);
    }

    function handleKeyPress(e) {
        if (e.key === 'Enter') {
            sendMessage();
        }
    }

    if (isAdmin) {
        connection.start().then(() => {
            connection.invoke("JoinChat", "Admin");
        });
    }
</script>