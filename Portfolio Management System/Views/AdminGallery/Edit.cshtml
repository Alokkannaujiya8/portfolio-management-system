@model GalleryModel
@{
    ViewData["Title"] = "Edit Gallery Item";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-edit me-2"></i>Edit Gallery Item</h2>
        <a href="@Url.Action("Index", "AdminGallery")" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="GalleryId" />

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MediaType" class="form-label">Media Type</label>
                            <input asp-for="MediaType" class="form-control" readonly disabled />
                        </div>

                        @if (Model.MediaType == "image")
                        {
                            <div class="mb-3">
                                <label class="form-label">Replace Image</label>
                                <input type="file" name="imageFile" class="form-control" accept="image/*" />
                                <small class="text-muted">Leave empty to keep current image</small>
                            </div>
                        }
                        else if (Model.MediaType == "video")
                        {
                            <div class="mb-3">
                                <label class="form-label">Replace Video File</label>
                                <input type="file" name="videoFile" class="form-control" accept="video/mp4,video/webm,video/ogg" />
                                <small class="text-muted">Leave empty to keep current video</small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">OR Update YouTube/Vimeo URL</label>
                                <input type="url" class="form-control" name="VideoEmbedCode" value="@Model.VideoEmbedCode" />
                            </div>
                        }
                        else if (Model.MediaType == "document")
                        {
                            <div class="mb-3">
                                <label class="form-label">Replace Document</label>
                                <input type="file" name="documentFile" class="form-control" accept=".pdf,.doc,.docx,.txt" />
                                <small class="text-muted">Leave empty to keep current document</small>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="Category" class="form-label">Category</label>
                            <input asp-for="Category" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Tags" class="form-label">Tags</label>
                            <input asp-for="Tags" class="form-control" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="mb-3">Current Media</h6>
                                @if (Model.MediaType == "image")
                                {
                                    <img src="@Model.MediaPath" class="img-fluid rounded" alt="@Model.Title" />
                                }
                                else if (Model.MediaType == "video")
                                {
                                    <div class="text-center p-3 bg-dark text-white rounded">
                                        <i class="fas fa-video fa-3x mb-2"></i>
                                        <p class="small mb-0">Video File</p>
                                    </div>
                                }
                                else if (Model.MediaType == "document")
                                {
                                    <div class="text-center p-3 bg-light rounded">
                                        <i class="fas fa-file-pdf fa-3x text-danger mb-2"></i>
                                        <p class="small mb-0">@System.IO.Path.GetFileName(Model.MediaPath)</p>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="card bg-light">
                            <div class="card-body">
                                <div class="mb-3">
                                    <div class="form-check">
                                        <input asp-for="IsFeatured" class="form-check-input" />
                                        <label asp-for="IsFeatured" class="form-check-label">Mark as Featured</label>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="DisplayOrder" class="form-label">Display Order</label>
                                    <input asp-for="DisplayOrder" type="number" class="form-control" />
                                </div>

                                <div class="text-muted small">
                                    <div>Views: @Model.ViewCount</div>
                                    <div>Downloads: @Model.DownloadCount</div>
                                    <div>Created: @Model.CreatedDate.ToString("MMM dd, yyyy")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="text-end">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save me-2"></i>Update Item
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>