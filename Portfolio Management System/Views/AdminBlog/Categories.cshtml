@model List<BlogCategoryModel>
@{
    ViewData["Title"] = "Categories";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-folder me-2"></i>Blog Categories</h2>
        <button class="btn btn-primary" onclick="showAddModal()">
            <i class="fas fa-plus me-2"></i>Add Category
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Slug</th>
                            <th>Description</th>
                            <th>Posts</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var cat in Model)
                            {
                                <tr id="category-@cat.CategoryId">
                                    <td>
                                        <i class="fas @(cat.Icon ?? "fa-folder") me-2 text-primary"></i>
                                        @cat.CategoryName
                                    </td>
                                    <td>@cat.Slug</td>
                                    <td>@(cat.Description?.Length > 50 ? cat.Description.Substring(0, 50) + "..." : cat.Description)</td>
                                    <td><span class="badge bg-primary">@cat.PostCount</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-warning" onclick="editCategory(@cat.CategoryId, '@cat.CategoryName', '@cat.Slug', '@cat.Description', '@cat.Icon', @cat.DisplayOrder)">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger" onclick="deleteCategory(@cat.CategoryId)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4">
                                    <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
                                    <p class="text-muted">No categories found. Click "Add Category" to create one.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="categoryModalLabel">
                    <i class="fas fa-folder me-2"></i>Add Category
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="categoryForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="categoryId" name="CategoryId" />
                    <input type="hidden" id="displayOrder" name="DisplayOrder" value="0" />

                    <div class="mb-3">
                        <label for="categoryName" class="form-label">Category Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="categoryName" name="CategoryName" required maxlength="100">
                    </div>

                    <div class="mb-3">
                        <label for="slug" class="form-label">Slug (URL)</label>
                        <input type="text" class="form-control" id="slug" name="Slug" placeholder="auto-generated-from-name">
                        <small class="text-muted">Leave empty to auto-generate from name</small>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea class="form-control" id="description" name="Description" rows="2" maxlength="500"></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="icon" class="form-label">Icon (Font Awesome Class)</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-icons"></i></span>
                            <input type="text" class="form-control" id="icon" name="Icon" placeholder="fa-folder, fa-code, etc.">
                        </div>
                        <small class="text-muted">Example: fa-folder, fa-code, fa-laptop</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Icon Preview</label>
                        <div class="p-3 border rounded text-center">
                            <i class="fas preview-icon fa-folder fa-2x text-primary"></i>
                            <p class="small text-muted mt-1" id="iconPreviewText">fa-folder</p>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveCategory()">
                    <i class="fas fa-save me-2"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this category?</p>
                <p class="text-danger small">Note: Categories with posts cannot be deleted.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log('Categories page loaded');

            // Auto-generate slug from name
            $('#categoryName').on('keyup', function() {
                if ($('#slug').val() === '') {
                    var slug = generateSlug($(this).val());
                    $('#slug').val(slug);
                }
            });

            // Update icon preview
            $('#icon').on('keyup change', function() {
                var iconClass = $(this).val().trim() || 'fa-folder';
                $('.preview-icon').removeClass().addClass('fas ' + iconClass + ' fa-2x text-primary');
                $('#iconPreviewText').text(iconClass);
            });
        });

        var deleteId = 0;
        var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

        // Show Add Modal
        window.showAddModal = function() {
            console.log('showAddModal called');

            resetForm();
            document.getElementById('categoryModalLabel').innerHTML = '<i class="fas fa-folder me-2"></i>Add Category';

            var modal = new bootstrap.Modal(document.getElementById('categoryModal'));
            modal.show();
        };

        // Show Edit Modal
        window.editCategory = function(id, name, slug, description, icon, displayOrder) {
            console.log('editCategory called', id, name, slug, description, icon, displayOrder);

            document.getElementById('categoryId').value = id;
            document.getElementById('categoryName').value = name;
            document.getElementById('slug').value = slug;
            document.getElementById('description').value = description || '';
            document.getElementById('icon').value = icon || 'fa-folder';
            document.getElementById('displayOrder').value = displayOrder || 0;

            // Update icon preview
            $('.preview-icon').removeClass().addClass('fas ' + (icon || 'fa-folder') + ' fa-2x text-primary');
            $('#iconPreviewText').text(icon || 'fa-folder');

            document.getElementById('categoryModalLabel').innerHTML = '<i class="fas fa-edit me-2"></i>Edit Category';

            var modal = new bootstrap.Modal(document.getElementById('categoryModal'));
            modal.show();
        };

        // Reset form
        function resetForm() {
            document.getElementById('categoryId').value = '';
            document.getElementById('categoryName').value = '';
            document.getElementById('slug').value = '';
            document.getElementById('description').value = '';
            document.getElementById('icon').value = 'fa-folder';
            document.getElementById('displayOrder').value = '0';
            $('.preview-icon').removeClass().addClass('fas fa-folder fa-2x text-primary');
            $('#iconPreviewText').text('fa-folder');
        }

        // Save Category
        window.saveCategory = function() {
            console.log('saveCategory called');

            var name = document.getElementById('categoryName').value.trim();

            if (!name) {
                alert('Please enter category name');
                return;
            }

            var id = document.getElementById('categoryId').value;
            var url = id ? '/AdminBlog/UpdateCategory' : '/AdminBlog/AddCategory';

            var formData = {
                CategoryId: id || 0,
                CategoryName: name,
                Slug: document.getElementById('slug').value.trim() || generateSlug(name),
                Description: document.getElementById('description').value.trim() || '',
                Icon: document.getElementById('icon').value.trim() || 'fa-folder',
                DisplayOrder: parseInt(document.getElementById('displayOrder').value) || 0
            };

            var saveBtn = event.target;
            var originalText = saveBtn.innerHTML;
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';

            $.ajax({
                url: url,
                type: 'POST',
                data: JSON.stringify(formData),
                contentType: 'application/json',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    console.log('Save success:', response);

                    var modal = bootstrap.Modal.getInstance(document.getElementById('categoryModal'));
                    if (modal) modal.hide();

                    alert(response.message || 'Category saved successfully!');
                    location.reload();
                },
                error: function(xhr) {
                    console.error('Save error:', xhr);

                    var errorMsg = 'Error saving category';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMsg = xhr.responseJSON.message;
                    }

                    alert(errorMsg);
                    saveBtn.disabled = false;
                    saveBtn.innerHTML = originalText;
                }
            });
        };

        // Generate slug helper
        function generateSlug(text) {
            return text.toLowerCase()
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-')
                .replace(/-+/g, '-')
                .replace(/^-|-$/g, '');
        }

        // Delete Category
        window.deleteCategory = function(id) {
            deleteId = id;
            deleteModal.show();
        };

        document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
            if (deleteId) {
                var deleteBtn = this;
                var originalText = deleteBtn.innerHTML;
                deleteBtn.disabled = true;
                deleteBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Deleting...';

                $.ajax({
                    url: '/AdminBlog/DeleteCategory',
                    type: 'POST',
                    data: { id: deleteId },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            document.getElementById('category-' + deleteId).remove();
                            deleteModal.hide();
                            alert(response.message || 'Category deleted successfully!');

                            if ($('#categories-table tbody tr').length === 0) {
                                location.reload();
                            }
                        } else {
                            alert(response.message || 'Error deleting category');
                            deleteBtn.disabled = false;
                            deleteBtn.innerHTML = originalText;
                        }
                    },
                    error: function(xhr) {
                        var errorMsg = 'An error occurred while deleting';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMsg = xhr.responseJSON.message;
                        }
                        alert(errorMsg);
                        deleteBtn.disabled = false;
                        deleteBtn.innerHTML = originalText;
                    }
                });
            }
        });

        // Handle modal hidden event
        $('#categoryModal').on('hidden.bs.modal', function() {
            resetForm();
        });
    </script>
}

<style>
    /* Custom styles for icon preview */
    .preview-icon {
        transition: all 0.3s ease;
    }

    .input-group-text {
        background-color: #f8f9fa;
    }

    .modal-content {
        border: none;
        border-radius: 15px;
    }

    .modal-header {
        border-radius: 15px 15px 0 0;
    }

    .btn-close-white {
        filter: brightness(0) invert(1);
    }
</style>