@model List<BlogPostModel>
@{
    ViewData["Title"] = "Blog Posts";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-blog me-2"></i>Blog Posts</h2>
        <a href="@Url.Action("Create", "AdminBlog")" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create New Post
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Views</th>
                            <th>Likes</th>
                            <th>Comments</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var post in Model)
                            {
                                <tr id="post-@post.PostId">
                                    <td>
                                        @if (!string.IsNullOrEmpty(post.FeaturedImage))
                                        {
                                            <img src="@post.FeaturedImage" alt="@post.Title" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; border-radius: 5px;">
                                                <i class="fas fa-image"></i>
                                            </div>
                                        }
                                    </td>
                                    <td>@post.Title</td>
                                    <td>@(post.Category?.CategoryName ?? "Uncategorized")</td>
                                    <td>@post.ViewCount</td>
                                    <td>@post.LikeCount</td>
                                    <td>@post.CommentCount</td>
                                    <td>
                                        @if (post.IsPublished)
                                        {
                                            <span class="badge bg-success">Published</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Draft</span>
                                        }
                                        @if (post.IsFeatured)
                                        {
                                            <span class="badge bg-info">Featured</span>
                                        }
                                    </td>
                                    <td>@post.CreatedDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <a href="@Url.Action("Edit", "AdminBlog", new { id = post.PostId })" class="btn btn-sm btn-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button class="btn btn-sm btn-danger" onclick="deletePost(@post.PostId)" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                        <!-- 👇 View button - opens in popup -->
                                        <button class="btn btn-sm btn-info" onclick="viewPost(@post.PostId, '@post.Slug')" title="View">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-4">
                                    <i class="fas fa-blog fa-3x text-muted mb-3"></i>
                                    <p class="text-muted">No blog posts yet. Click "Create New Post" to add one.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- View Post Modal -->
<div class="modal fade" id="viewPostModal" tabindex="-1" aria-labelledby="viewPostModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="viewPostModalLabel">
                    <i class="fas fa-eye me-2"></i>View Post
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="postModalBody">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Loading post...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deletePost(id) {
            if (confirm('Are you sure you want to delete this post?')) {
                $.ajax({
                    url: '@Url.Action("Delete", "AdminBlog")',
                    type: 'POST',
                    data: { id: id },
                    success: function(response) {
                        if (response.success) {
                            $('#post-' + id).fadeOut(500, function() { $(this).remove(); });
                            alert('Post deleted successfully');
                        } else {
                            alert(response.message || 'Error deleting post');
                        }
                    },
                    error: function() {
                        alert('An error occurred');
                    }
                });
            }
        }

        function viewPost(id, slug) {
            // Show modal with loading
            $('#viewPostModal').modal('show');

            // Fetch post content via AJAX
            $.ajax({
                url: '/Blog/GetPostJson/' + id,
                type: 'GET',
                success: function(post) {
                    displayPostInModal(post);
                },
                error: function() {
                    $('#postModalBody').html(`
                        <div class="alert alert-danger m-3">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            Error loading post. Please try again.
                        </div>
                    `);
                }
            });
        }

        function displayPostInModal(post) {
            var html = `
                <div class="container-fluid p-4">
                    <!-- Featured Image -->
                    ${post.featuredImage ? `
                        <div class="text-center mb-4">
                            <img src="${post.featuredImage}" class="img-fluid rounded-4 shadow" style="max-height: 300px; width: auto;" alt="${post.title}">
                        </div>
                    ` : ''}

                    <!-- Title -->
                    <h1 class="h2 mb-3">${post.title}</h1>

                    <!-- Meta Info -->
                    <div class="d-flex text-muted mb-4 flex-wrap">
                        <span class="me-3"><i class="far fa-calendar me-1"></i>${new Date(post.createdDate).toLocaleDateString()}</span>
                        <span class="me-3"><i class="far fa-clock me-1"></i>${post.readingTime}</span>
                        <span class="me-3"><i class="far fa-eye me-1"></i>${post.viewCount} views</span>
                        <span><i class="far fa-heart me-1"></i>${post.likeCount} likes</span>
                    </div>

                    <!-- Category -->
                    ${post.category ? `
                        <div class="mb-4">
                            <span class="badge bg-primary p-2">
                                <i class="fas fa-folder me-1"></i>${post.category.categoryName}
                            </span>
                        </div>
                    ` : ''}

                    <!-- Content -->
                    <div class="blog-content mt-4">
                        ${post.content}
                    </div>

                    <!-- Tags -->
                    ${post.tags ? `
                        <div class="mt-4">
                            <strong>Tags:</strong>
                            ${post.tags.split(',').map(tag =>
                                `<span class="badge bg-light text-dark me-2 p-2">#${tag.trim()}</span>`
                            ).join('')}
                        </div>
                    ` : ''}
                </div>
            `;

            $('#postModalBody').html(html);
        }
    </script>
}