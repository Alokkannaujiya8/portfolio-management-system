@model List<BlogCommentModel>
@{
    ViewData["Title"] = "Manage Comments";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-comments me-2"></i>Blog Comments</h2>
        <div>
            <span class="badge bg-warning me-2">Pending: @(Model?.Count(c => !c.IsApproved) ?? 0)</span>
            <span class="badge bg-success">Approved: @(Model?.Count(c => c.IsApproved) ?? 0)</span>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter Tabs -->
    <ul class="nav nav-tabs mb-4" id="commentTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button" role="tab">All Comments</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab">Pending Approval</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="approved-tab" data-bs-toggle="tab" data-bs-target="#approved" type="button" role="tab">Approved</button>
        </li>
    </ul>

    <div class="tab-content" id="commentTabsContent">
        <!-- All Comments Tab -->
        <div class="tab-pane fade show active" id="all" role="tabpanel">
            @await Html.PartialAsync("_CommentListPartial", Model)
        </div>

        <!-- Pending Comments Tab -->
        <div class="tab-pane fade" id="pending" role="tabpanel">
            @await Html.PartialAsync("_CommentListPartial", Model?.Where(c => !c.IsApproved).ToList())
        </div>

        <!-- Approved Comments Tab -->
        <div class="tab-pane fade" id="approved" role="tabpanel">
            @await Html.PartialAsync("_CommentListPartial", Model?.Where(c => c.IsApproved).ToList())
        </div>
    </div>
</div>

<!-- View Comment Modal -->
<div class="modal fade" id="viewCommentModal" tabindex="-1" aria-labelledby="viewCommentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="viewCommentModalLabel">
                    <i class="fas fa-comment me-2"></i>Comment Details
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Name:</label>
                        <p id="viewName" class="border-bottom pb-2"></p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Email:</label>
                        <p id="viewEmail" class="border-bottom pb-2"></p>
                    </div>
                    <div class="col-12 mb-3">
                        <label class="fw-bold">Website:</label>
                        <p id="viewWebsite" class="border-bottom pb-2"></p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Post:</label>
                        <p id="viewPost" class="border-bottom pb-2"></p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Date:</label>
                        <p id="viewDate" class="border-bottom pb-2"></p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">IP Address:</label>
                        <p id="viewIP" class="border-bottom pb-2"></p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Status:</label>
                        <p id="viewStatus" class="border-bottom pb-2"></p>
                    </div>
                    <div class="col-12 mb-3">
                        <label class="fw-bold">Comment:</label>
                        <p id="viewComment" class="border p-3 rounded bg-light"></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Reply Modal -->
<div class="modal fade" id="replyModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-reply me-2"></i>Reply to Comment
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="replyForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="replyCommentId" name="ParentCommentId" />
                    <input type="hidden" id="replyPostId" name="PostId" />

                    <div class="mb-3">
                        <label class="form-label">Your Name</label>
                        <input type="text" class="form-control" id="replyName" value="Admin" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Your Email</label>
                        <input type="email" class="form-control" id="replyEmail" value="admin@portfolio.com" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Reply</label>
                        <textarea class="form-control" id="replyMessage" rows="4" required></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitReply()">
                    <i class="fas fa-paper-plane me-2"></i>Send Reply
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // View Comment
        window.viewComment = function(id, name, email, website, post, date, ip, status, comment) {
            document.getElementById('viewName').textContent = name || 'N/A';
            document.getElementById('viewEmail').textContent = email || 'N/A';
            document.getElementById('viewWebsite').textContent = website || 'N/A';
            document.getElementById('viewPost').textContent = post || 'N/A';
            document.getElementById('viewDate').textContent = date;
            document.getElementById('viewIP').textContent = ip || 'N/A';
            document.getElementById('viewStatus').innerHTML = status ?
                '<span class="badge bg-success">Approved</span>' :
                '<span class="badge bg-warning">Pending</span>';
            document.getElementById('viewComment').textContent = comment;

            var modal = new bootstrap.Modal(document.getElementById('viewCommentModal'));
            modal.show();
        };

        // Approve Comment
        window.approveComment = function(id) {
            if (confirm('Approve this comment?')) {
                $.ajax({
                    url: '/AdminBlog/ApproveComment',
                    type: 'POST',
                    data: { id: id },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            alert('Comment approved successfully!');
                            location.reload();
                        } else {
                            alert(response.message || 'Error approving comment');
                        }
                    },
                    error: function() {
                        alert('An error occurred');
                    }
                });
            }
        };

        // Delete Comment
        window.deleteComment = function(id) {
            if (confirm('Are you sure you want to delete this comment?')) {
                $.ajax({
                    url: '/AdminBlog/DeleteComment',
                    type: 'POST',
                    data: { id: id },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            document.getElementById('comment-' + id).remove();
                            alert('Comment deleted successfully!');
                        } else {
                            alert(response.message || 'Error deleting comment');
                        }
                    },
                    error: function() {
                        alert('An error occurred');
                    }
                });
            }
        };

        // Show Reply Modal
        window.showReplyModal = function(commentId, postId, name) {
            document.getElementById('replyCommentId').value = commentId;
            document.getElementById('replyPostId').value = postId;
            document.getElementById('replyMessage').placeholder = 'Reply to ' + name + '...';

            var modal = new bootstrap.Modal(document.getElementById('replyModal'));
            modal.show();
        };

        // Submit Reply
        window.submitReply = function() {
            var data = {
                ParentCommentId: parseInt(document.getElementById('replyCommentId').value),
                PostId: parseInt(document.getElementById('replyPostId').value),
                Name: document.getElementById('replyName').value,
                Email: document.getElementById('replyEmail').value,
                Comment: document.getElementById('replyMessage').value,
                IsApproved: true
            };

            if (!data.Comment) {
                alert('Please enter a reply');
                return;
            }

            var replyBtn = event.target;
            var originalText = replyBtn.innerHTML;
            replyBtn.disabled = true;
            replyBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Sending...';

            $.ajax({
                url: '/AdminBlog/AddComment',
                type: 'POST',
                data: JSON.stringify(data),
                contentType: 'application/json',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        var modal = bootstrap.Modal.getInstance(document.getElementById('replyModal'));
                        modal.hide();
                        alert('Reply sent successfully!');
                        location.reload();
                    } else {
                        alert(response.message || 'Error sending reply');
                        replyBtn.disabled = false;
                        replyBtn.innerHTML = originalText;
                    }
                },
                error: function() {
                    alert('An error occurred');
                    replyBtn.disabled = false;
                    replyBtn.innerHTML = originalText;
                }
            });
        };
    </script>
}