@model List<EducationModel>
@{
    ViewData["Title"] = "Manage Education";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-graduation-cap me-2"></i>Education</h2>
        <button class="btn btn-primary" onclick="showAddModal()" id="addEducationBtn">
            <i class="fas fa-plus me-2"></i>Add Education
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Degree</th>
                            <th>Institute</th>
                            <th>Year</th>
                            <th>Percentage</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var edu in Model)
                            {
                                <tr id="edu-@edu.EducationId">
                                    <td>@edu.Degree</td>
                                    <td>@edu.Institute</td>
                                    <td>@edu.Year</td>
                                    <td>@(edu.Percentage?.ToString() + "%")</td>
                                    <td>
                                        <button class="btn btn-sm btn-warning" onclick="editEducation(@edu.EducationId, '@edu.Degree', '@edu.Institute', @edu.Year, '@(edu.Percentage?.ToString() ?? "")')">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger" onclick="deleteEducation(@edu.EducationId)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4">
                                    <i class="fas fa-graduation-cap fa-3x text-muted mb-3"></i>
                                    <p class="text-muted">No education records found. Click "Add Education" to add one.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="educationModal" tabindex="-1" aria-labelledby="educationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="educationModalLabel">
                    <i class="fas fa-graduation-cap me-2"></i>Add Education
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="educationForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="educationId" name="EducationId" />

                    <div class="mb-3">
                        <label for="degree" class="form-label">Degree <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="degree" name="Degree" required>
                    </div>

                    <div class="mb-3">
                        <label for="institute" class="form-label">Institute <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="institute" name="Institute" required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="year" class="form-label">Year <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="year" name="Year" min="1900" max="2100" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="percentage" class="form-label">Percentage</label>
                            <input type="number" class="form-control" id="percentage" name="Percentage" step="0.01" min="0" max="100">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveEducation()">
                    <i class="fas fa-save me-2"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this education record?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log('Education page loaded');
        });

        var deleteId = 0;
        var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

        // Show Add Modal
        window.showAddModal = function() {
            console.log('showAddModal called');

            document.getElementById('educationId').value = '';
            document.getElementById('degree').value = '';
            document.getElementById('institute').value = '';
            document.getElementById('year').value = '';
            document.getElementById('percentage').value = '';
            document.getElementById('educationModalLabel').innerHTML = '<i class="fas fa-graduation-cap me-2"></i>Add Education';

            var modal = new bootstrap.Modal(document.getElementById('educationModal'));
            modal.show();
        };

        // Show Edit Modal
        window.editEducation = function(id, degree, institute, year, percentage) {
            console.log('editEducation called', id, degree, institute, year, percentage);

            document.getElementById('educationId').value = id;
            document.getElementById('degree').value = degree;
            document.getElementById('institute').value = institute;
            document.getElementById('year').value = year;
            document.getElementById('percentage').value = percentage;
            document.getElementById('educationModalLabel').innerHTML = '<i class="fas fa-edit me-2"></i>Edit Education';

            var modal = new bootstrap.Modal(document.getElementById('educationModal'));
            modal.show();
        };

        // Save Education
        window.saveEducation = function() {
            console.log('saveEducation called');

            var degree = document.getElementById('degree').value.trim();
            var institute = document.getElementById('institute').value.trim();
            var year = document.getElementById('year').value.trim();

            if (!degree) {
                alert('Please enter degree');
                return;
            }
            if (!institute) {
                alert('Please enter institute');
                return;
            }
            if (!year) {
                alert('Please enter year');
                return;
            }

            var id = document.getElementById('educationId').value;
            var url = id ? '/Admin/UpdateEducation' : '/Admin/AddEducation';

            var formData = {
                EducationId: id || 0,
                Degree: degree,
                Institute: institute,
                Year: parseInt(year),
                Percentage: document.getElementById('percentage').value ? parseFloat(document.getElementById('percentage').value) : null
            };

            var saveBtn = event.target;
            var originalText = saveBtn.innerHTML;
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';

            $.ajax({
                url: url,
                type: 'POST',
                data: formData,
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    console.log('Save success:', response);

                    var modal = bootstrap.Modal.getInstance(document.getElementById('educationModal'));
                    if (modal) modal.hide();

                    alert(response.message || 'Education saved successfully!');
                    location.reload();
                },
                error: function(xhr) {
                    console.error('Save error:', xhr);

                    var errorMsg = 'Error saving education';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMsg = xhr.responseJSON.message;
                    }

                    alert(errorMsg);
                    saveBtn.disabled = false;
                    saveBtn.innerHTML = originalText;
                }
            });
        };

        // Delete Education
        window.deleteEducation = function(id) {
            deleteId = id;
            deleteModal.show();
        };

        document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
            if (deleteId) {
                $.ajax({
                    url: '/Admin/DeleteEducation',
                    type: 'POST',
                    data: { id: deleteId },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            document.getElementById('edu-' + deleteId).remove();
                            deleteModal.hide();
                            alert(response.message || 'Education deleted successfully!');

                            if ($('#education-table tbody tr').length === 0) {
                                location.reload();
                            }
                        } else {
                            alert('Error deleting education');
                        }
                    },
                    error: function(xhr) {
                        alert('An error occurred while deleting');
                    }
                });
            }
        });
    </script>
}