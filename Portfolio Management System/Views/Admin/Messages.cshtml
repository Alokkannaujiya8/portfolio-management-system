@model List<ContactMessageModel>
@{
    ViewData["Title"] = "Messages";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <h2 class="mb-4"><i class="fas fa-envelope me-2"></i>Contact Messages</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Subject</th>
                            <th>Message</th>
                            <th>Date</th>
                            <th>IP Address</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var message in Model)
                        {
                            <tr id="message-@message.MessageId" class="@(!message.IsRead ? "fw-bold" : "")">
                                <td>
                                    @if (!message.IsRead)
                                    {
                                        <span class="badge bg-warning">New</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Read</span>
                                    }
                                </td>
                                <td>@message.Name</td>
                                <td>@message.Email</td>
                                <td>@message.Subject</td>
                                <td>@(message.Message?.Length > 50 ? message.Message.Substring(0, 50) + "..." : message.Message)</td>
                                <td>@message.CreatedDate.ToString("MMM dd, yyyy HH:mm")</td>
                                <td>@message.IPAddress</td>
                                <td>
                                    <button class="btn btn-sm btn-info" onclick="viewMessage(@message.MessageId, '@message.Name', '@message.Email', '@message.Subject', '@message.Message', '@message.CreatedDate.ToString("yyyy-MM-dd HH:mm")', '@message.IPAddress')">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    @if (!message.IsRead)
                                    {
                                        <button class="btn btn-sm btn-success" onclick="markAsRead(@message.MessageId)">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- View Message Modal -->
<div class="modal fade" id="viewMessageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Message Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="fw-bold">From:</label>
                    <p id="viewName" class="mb-0"></p>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Email:</label>
                    <p id="viewEmail" class="mb-0"></p>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Subject:</label>
                    <p id="viewSubject" class="mb-0"></p>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Date:</label>
                    <p id="viewDate" class="mb-0"></p>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">IP Address:</label>
                    <p id="viewIP" class="mb-0"></p>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Message:</label>
                    <p id="viewMessage" class="mb-0 border p-3 rounded"></p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function viewMessage(id, name, email, subject, message, date, ip) {
            $('#viewName').text(name);
            $('#viewEmail').text(email);
            $('#viewSubject').text(subject || '(No subject)');
            $('#viewDate').text(date);
            $('#viewIP').text(ip || 'Unknown');
            $('#viewMessage').text(message);
            $('#viewMessageModal').modal('show');

            // Mark as read when viewed
            markAsRead(id);
        }

        function markAsRead(id) {
            $.ajax({
                url: '/Admin/MarkMessageAsRead',
                type: 'POST',
                data: { id: id },
                success: function() {
                    $('#message-' + id).find('.badge').removeClass('bg-warning').addClass('bg-secondary').text('Read');
                    $('#message-' + id).removeClass('fw-bold');
                    $('#message-' + id).find('button.btn-success').remove();
                }
            });
        }
    </script>
}