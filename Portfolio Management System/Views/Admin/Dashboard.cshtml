@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";

    // Session values
    var username = Context.Session.GetString("Admin") ?? "Admin";
    var loginTime = Context.Session.GetString("AdminLoginTime") ?? DateTime.Now.ToString("dd/MM/yyyy HH:mm");
    var experienceDetail = ViewBag.ExperienceDetail as TotalExperienceDetail ?? new TotalExperienceDetail();
}


<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1"><i class="fas fa-tachometer-alt me-2 text-primary"></i>Dashboard</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Dashboard", "Admin")">Home</a></li>
                <li class="breadcrumb-item active">Dashboard</li>
            </ol>
        </nav>
    </div>
    <div>
        <button class="btn btn-outline-primary" onclick="refreshDashboard()">
            <i class="fas fa-sync-alt me-2"></i>Refresh
        </button>
    </div>
</div>

<!-- Welcome Card -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card bg-gradient-primary text-white border-0 shadow-lg">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h4 class="mb-2">Welcome back, <strong>@username</strong>! 👋</h4>
                        <p class="mb-3 opacity-75">Last login: @loginTime</p>
                        <div class="d-flex gap-4 flex-wrap">
                            <div>
                                <small class="opacity-75">Today's Visitors</small>
                                <h5 class="mb-0">@Model.TodayVisitors</h5>
                            </div>
                            <div class="vr bg-white opacity-25"></div>
                            <div>
                                <small class="opacity-75">Active Chats</small>
                                <h5 class="mb-0">@Model.ActiveChats</h5>
                            </div>
                            <div class="vr bg-white opacity-25"></div>
                            <div>
                                <small class="opacity-75">Page Views</small>
                                <h5 class="mb-0">@Model.TotalPageViews</h5>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                        <i class="fas fa-chart-line fa-4x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Statistics Cards -->
<div class="row g-4 mb-4">
    <!-- Skills Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100 stat-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-primary bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="fas fa-chart-bar fa-2x text-primary"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Total Skills</h6>
                        <h3 class="mb-0">@Model.TotalSkills</h3>
                        <small class="text-success"><i class="fas fa-arrow-up me-1"></i>Active</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Projects Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100 stat-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-success bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="fas fa-project-diagram fa-2x text-success"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Total Projects</h6>
                        <h3 class="mb-0">@Model.TotalProjects</h3>
                        <small class="text-success">Completed</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Experience Card - Updated with accurate calculation -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100 stat-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-info bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="fas fa-briefcase fa-2x text-info"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Experience</h6>
                        <h3 class="mb-0">@Model.TotalExperience</h3>
                        <small class="text-info">Years of Experience</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Messages Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100 stat-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-warning bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="fas fa-envelope fa-2x text-warning"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Messages</h6>
                        <h3 class="mb-0">@Model.TotalMessages</h3>
                        <small class="text-danger">@Model.UnreadMessages unread</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Resume Views Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100 stat-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-danger bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="fas fa-file-pdf fa-2x text-danger"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Resume Views</h6>
                        <h3 class="mb-0">@Model.TotalResumeViews</h3>
                        <small class="text-success">@Model.TotalDownloads downloads</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Blog Posts Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100 stat-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon" style="background: rgba(128,0,128,0.1); padding: 1rem; border-radius: 0.5rem; margin-right: 1rem;">
                        <i class="fas fa-blog fa-2x" style="color: purple;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Blog Posts</h6>
                        <h3 class="mb-0">@Model.TotalBlogPosts</h3>
                        <small class="text-warning">@Model.PendingComments pending</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Gallery Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100 stat-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon" style="background: rgba(255,192,203,0.1); padding: 1rem; border-radius: 0.5rem; margin-right: 1rem;">
                        <i class="fas fa-images fa-2x" style="color: #ff69b4;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Gallery Items</h6>
                        <h3 class="mb-0">@Model.TotalGalleryItems</h3>
                        <small class="text-info">Media files</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Education Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100 stat-card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-secondary bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="fas fa-graduation-cap fa-2x text-secondary"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Education</h6>
                        <h3 class="mb-0">@Model.TotalEducation</h3>
                        <small class="text-secondary">Degrees</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Experience Details Section - NEW -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <h5 class="mb-0">
                    <i class="fas fa-chart-line me-2 text-primary"></i>Experience Overview
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3 mb-md-0">
                        <div class="text-center p-3 bg-light rounded-3">
                            <div class="display-4 fw-bold text-primary">@Model.TotalExperience</div>
                            <div class="text-muted">Total Years Experience</div>
                            <small class="text-info">Combined across all positions</small>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="row text-center">
                            <div class="col-6">
                                <div class="p-3">
                                    <i class="fas fa-briefcase fa-2x text-success mb-2"></i>
                                    <div class="fw-bold">Current Role</div>
                                    <small class="text-muted" id="currentJobDuration">Loading...</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3">
                                    <i class="fas fa-history fa-2x text-warning mb-2"></i>
                                    <div class="fw-bold">Past Experience</div>
                                    <small class="text-muted" id="pastJobDuration">Loading...</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Visitors Chart -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <h5 class="mb-0">
                    <i class="fas fa-chart-line me-2 text-primary"></i>Visitors Overview (Last 7 Days)
                </h5>
            </div>
            <div class="card-body">
                <canvas id="visitorsChart" height="300"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activities -->
<div class="row g-4 mb-4">
    <!-- Recent Messages -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-envelope me-2 text-primary"></i>Recent Messages
                </h5>
                <a href="@Url.Action("Messages", "Admin")" class="btn btn-sm btn-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (Model.RecentMessages != null && Model.RecentMessages.Any())
                    {
                        @foreach (var msg in Model.RecentMessages.Take(5))
                        {
                            <div class="list-group-item list-group-item-action">
                                <div class="d-flex w-100 justify-content-between align-items-start">
                                    <div class="d-flex">
                                        <div class="avatar-circle bg-primary text-white me-3">
                                            @(msg.Name.Length > 0 ? msg.Name.Substring(0, 1).ToUpper() : "?")
                                        </div>
                                        <div>
                                            <h6 class="mb-1">@msg.Name</h6>
                                            <p class="mb-1 text-muted small">@(msg.Message?.Length > 30 ? msg.Message.Substring(0, 30) + "..." : msg.Message)</p>
                                            <small class="text-muted">
                                                <i class="far fa-clock me-1"></i>@msg.CreatedDate.ToString("MMM dd, HH:mm")
                                            </small>
                                        </div>
                                    </div>
                                    @if (!msg.IsRead)
                                    {
                                        <span class="badge bg-warning">New</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No messages yet</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Resume Views -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-file-pdf me-2 text-danger"></i>Recent Resume Views
                </h5>
                <a href="@Url.Action("ResumeViews", "Admin")" class="btn btn-sm btn-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (Model.RecentResumeViews != null && Model.RecentResumeViews.Any())
                    {
                        @foreach (var view in Model.RecentResumeViews.Take(5))
                        {
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">@(view.VisitorName ?? "Anonymous")</h6>
                                        <p class="mb-1 text-muted small">
                                            @view.CompanyName @(!string.IsNullOrEmpty(view.Designation) ? "• " + view.Designation : "")
                                        </p>
                                        <small class="text-muted">
                                            <i class="fas fa-map-marker-alt me-1"></i>@(view.City ?? "Unknown"), @(view.Country ?? "Unknown")
                                            <i class="far fa-clock ms-2 me-1"></i>@view.ViewDate.ToString("MMM dd")
                                        </small>
                                    </div>
                                    @if (view.IsDownloaded)
                                    {
                                        <span class="badge bg-success">Downloaded</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-file-pdf fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No resume views yet</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Visitors -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent">
                <h5 class="mb-0">
                    <i class="fas fa-users me-2 text-info"></i>Recent Visitors
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (Model.RecentVisitors != null && Model.RecentVisitors.Any())
                    {
                        @foreach (var visitor in Model.RecentVisitors.Take(5))
                        {
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">IP: @visitor.IPAddress</h6>
                                        <p class="mb-1 text-muted small">
                                            <i class="fas fa-map-marker-alt me-1"></i>@visitor.City, @visitor.Country
                                        </p>
                                        <small class="text-muted">
                                            <i class="far fa-clock me-1"></i>@visitor.LastVisit.ToString("MMM dd, HH:mm")
                                            <i class="fas fa-eye ms-2 me-1"></i>@visitor.VisitCount visits
                                        </small>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-users fa-3x text-muted mb-3"></i>
                            <p class="text-muted">No visitors yet</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <h5 class="mb-0">
                    <i class="fas fa-bolt me-2 text-warning"></i>Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-2 col-sm-4">
                        <a href="@Url.Action("Profile", "Admin")" class="btn btn-outline-primary w-100 p-3 quick-action-btn">
                            <i class="fas fa-user-edit fa-2x mb-2"></i>
                            <div class="small">Edit Profile</div>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4">
                        <a href="@Url.Action("Skills", "Admin")" class="btn btn-outline-success w-100 p-3 quick-action-btn">
                            <i class="fas fa-chart-bar fa-2x mb-2"></i>
                            <div class="small">Manage Skills</div>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4">
                        <a href="@Url.Action("Projects", "Admin")" class="btn btn-outline-info w-100 p-3 quick-action-btn">
                            <i class="fas fa-project-diagram fa-2x mb-2"></i>
                            <div class="small">Manage Projects</div>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4">
                        <a href="@Url.Action("Experience", "Admin")" class="btn btn-outline-warning w-100 p-3 quick-action-btn">
                            <i class="fas fa-briefcase fa-2x mb-2"></i>
                            <div class="small">Manage Experience</div>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4">
                        <a href="@Url.Action("Index", "AdminBlog")" class="btn btn-outline-info w-100 p-3 quick-action-btn">
                            <i class="fas fa-blog fa-2x mb-2"></i>
                            <div class="small">New Blog Post</div>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4">
                        <a href="@Url.Action("Messages", "Admin")" class="btn btn-outline-secondary w-100 p-3 quick-action-btn">
                            <i class="fas fa-envelope fa-2x mb-2"></i>
                            <div class="small">View Messages</div>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4">
                        <a href="@Url.Action("Logout", "Admin")" class="btn btn-outline-danger w-100 p-3 quick-action-btn">
                            <i class="fas fa-sign-out-alt fa-2x mb-2"></i>
                            <div class="small">Logout</div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Initialize Visitors Chart
        var ctx = document.getElementById('visitorsChart').getContext('2d');
        var visitorsChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.VisitorChartLabels ?? new string[0])),
                datasets: [{
                    label: 'Visitors',
                    data: @Html.Raw(Json.Serialize(Model.VisitorChartData ?? new int[0])),
                    borderColor: '#4361ee',
                    backgroundColor: 'rgba(67, 97, 238, 0.1)',
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#4361ee',
                    pointBorderColor: '#fff',
                    pointRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });

        // Refresh dashboard
        function refreshDashboard() {
            location.reload();
        }

        // Load experience details via AJAX
        function loadExperienceDetails() {
            $.ajax({
                url: '/Admin/GetExperienceDetails',
                type: 'GET',
                success: function(data) {
                    if (data) {
                        $('#currentJobDuration').text(data.currentFormatted || 'No current job');
                        $('#pastJobDuration').text(data.pastFormatted || 'No past experience');

                        // Update the experience card with detailed info
                        if (data.formatted) {
                            $('.stat-card:has(.fa-briefcase) h3').text(data.yearsOnly);
                            $('.stat-card:has(.fa-briefcase) small').text(data.formatted);
                        }
                    }
                },
                error: function() {
                    $('#currentJobDuration').text('Unable to load');
                    $('#pastJobDuration').text('Unable to load');
                }
            });
        }

        // Load experience details on page load
        $(document).ready(function() {
            loadExperienceDetails();

            // Auto refresh every 5 minutes
            setInterval(loadExperienceDetails, 300000);
        });
    </script>
}

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .stat-card {
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
        }

    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 1.1rem;
    }

    .quick-action-btn {
        transition: all 0.3s;
    }

        .quick-action-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
</style>