@model List<ProjectModel>
@{
    ViewData["Title"] = "Manage Projects";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-project-diagram me-2"></i>Manage Projects</h2>
        <button class="btn btn-primary" onclick="showAddModal()">
            <i class="fas fa-plus me-2"></i>Add New Project
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Project Name</th>
                            <th>Description</th>
                            <th>Links</th>
                            <th>Created Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var project in Model)
                        {
                            <tr id="project-@project.ProjectId">
                                <td>
                                    @if (!string.IsNullOrEmpty(project.ImagePath))
                                    {
                                        <img src="@project.ImagePath" alt="@project.ProjectName" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;">
                                    }
                                    else
                                    {
                                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; border-radius: 5px;">
                                            <i class="fas fa-image"></i>
                                        </div>
                                    }
                                </td>
                                <td>@Html.Raw(project.ProjectName)</td>
                                <td>@Html.Raw(project.Description?.Length > 50 ? project.Description.Substring(0, 50) + "..." : project.Description)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(project.LiveLink))
                                    {
                                        <a href="@project.LiveLink" target="_blank" class="btn btn-sm btn-success me-1" title="Live Demo">
                                            <i class="fas fa-external-link-alt"></i>
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(project.GitHubLink))
                                    {
                                        <a href="@project.GitHubLink" target="_blank" class="btn btn-sm btn-dark" title="GitHub">
                                            <i class="fab fa-github"></i>
                                        </a>
                                    }
                                </td>
                                <td>@project.CreatedDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <button class="btn btn-sm btn-warning edit-project-btn"
                                            data-id="@project.ProjectId"
                                            data-name="@System.Text.Encodings.Web.HtmlEncoder.Default.Encode(project.ProjectName)"
                                            data-description="@System.Text.Encodings.Web.HtmlEncoder.Default.Encode(project.Description ?? "")"
                                            data-livelink="@project.LiveLink"
                                            data-githublink="@project.GitHubLink">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteProject(@project.ProjectId)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="projectModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="projectModalTitle">Add Project</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="projectForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="projectId" name="ProjectId" />

                    <div class="mb-3">
                        <label class="form-label">Project Name</label>
                        <input type="text" class="form-control" id="projectName" name="ProjectName" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" id="projectDescription" name="Description" rows="3"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Live Demo Link</label>
                            <input type="url" class="form-control" id="liveLink" name="LiveLink" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">GitHub Link</label>
                            <input type="url" class="form-control" id="githubLink" name="GitHubLink" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Project Image</label>
                        <input type="file" class="form-control" id="imageFile" name="imageFile" accept="image/*" />
                        <small class="text-muted">Leave empty to keep existing image</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveProject()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize edit buttons with event handler
            $('.edit-project-btn').on('click', function() {
                var id = $(this).data('id');
                var name = $(this).data('name');
                var description = $(this).data('description');
                var liveLink = $(this).data('livelink');
                var githubLink = $(this).data('githublink');

                editProject(id, name, description, liveLink, githubLink);
            });
        });

        function showAddModal() {
            $('#projectId').val('');
            $('#projectName').val('');
            $('#projectDescription').val('');
            $('#liveLink').val('');
            $('#githubLink').val('');
            $('#imageFile').val('');
            $('#projectModalTitle').text('Add Project');
            $('#projectModal').modal('show');
        }

        function editProject(id, name, description, liveLink, githubLink) {
            // Decode HTML entities
            var decodedName = decodeHtml(name);
            var decodedDescription = decodeHtml(description);

            $('#projectId').val(id);
            $('#projectName').val(decodedName);
            $('#projectDescription').val(decodedDescription);
            $('#liveLink').val(liveLink);
            $('#githubLink').val(githubLink);
            $('#imageFile').val('');
            $('#projectModalTitle').text('Edit Project');
            $('#projectModal').modal('show');
        }

        // Function to decode HTML entities
        function decodeHtml(html) {
            if (!html) return '';
            var txt = document.createElement('textarea');
            txt.innerHTML = html;
            return txt.value;
        }

        function saveProject() {
            var formData = new FormData($('#projectForm')[0]);
            var id = $('#projectId').val();
            var url = id ? '/Admin/UpdateProject' : '/Admin/AddProject';

            // Show loading state
            var saveBtn = $(event.currentTarget);
            var originalText = saveBtn.text();
            saveBtn.prop('disabled', true).text('Saving...');

            $.ajax({
                url: url,
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        // Show success message
                        showToast('success', response.message || 'Project saved successfully');
                        // Reload after short delay
                        setTimeout(function() {
                            location.reload();
                        }, 1000);
                    } else {
                        showToast('error', response.message || 'Error saving project');
                        saveBtn.prop('disabled', false).text(originalText);
                    }
                },
                error: function(xhr) {
                    var errorMsg = xhr.responseJSON?.message || 'An error occurred while saving the project';
                    showToast('error', errorMsg);
                    saveBtn.prop('disabled', false).text(originalText);
                }
            });
        }

        function deleteProject(id) {
            if (confirm('Are you sure you want to delete this project?')) {
                $.ajax({
                    url: '/Admin/DeleteProject',
                    type: 'POST',
                    data: { id: id },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            $('#project-' + id).fadeOut(300, function() {
                                $(this).remove();
                            });
                            showToast('success', response.message || 'Project deleted successfully');
                        } else {
                            showToast('error', response.message || 'Error deleting project');
                        }
                    },
                    error: function() {
                        showToast('error', 'An error occurred while deleting the project');
                    }
                });
            }
        }

        // Toast notification function
        function showToast(type, message) {
            var toastHtml = `
                <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
                    <div class="toast align-items-center text-white bg-${type === 'success' ? 'success' : 'danger'} border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="3000">
                        <div class="d-flex">
                            <div class="toast-body">
                                ${message}
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>
                    </div>
                </div>
            `;

            $('body').append(toastHtml);
            var toast = $('.toast').last();
            var bsToast = new bootstrap.Toast(toast[0]);
            bsToast.show();

            // Remove toast after it's hidden
            toast.on('hidden.bs.toast', function() {
                $(this).parent().remove();
            });
        }
    </script>
}