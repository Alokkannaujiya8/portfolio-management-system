@model ProfileModel
@{
    ViewData["Title"] = "Profile";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <h2 class="mb-4"><i class="fas fa-user me-2"></i>Edit Profile</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Profile" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="row">
                    <div class="col-md-8">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label">Full Name</label>
                                <input asp-for="Name" class="form-control" required />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Title" class="form-label">Professional Title</label>
                                <input asp-for="Title" class="form-control" required />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="Description" class="form-label">About Me</label>
                                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label">Email</label>
                                <input asp-for="Email" type="email" class="form-control" required />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label">Phone</label>
                                <input asp-for="Phone" class="form-control" />
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="Address" class="form-label">Address</label>
                                <input asp-for="Address" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="LinkedIn" class="form-label">LinkedIn URL</label>
                                <input asp-for="LinkedIn" class="form-control" placeholder="https://linkedin.com/in/username" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="GitHub" class="form-label">GitHub URL</label>
                                <input asp-for="GitHub" class="form-control" placeholder="https://github.com/username" />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card bg-light mb-3">
                            <div class="card-body text-center">
                                <h6 class="mb-3">Profile Photo</h6>
                                @if (!string.IsNullOrEmpty(Model.Photo))
                                {
                                    <img src="@Model.Photo" alt="Profile" class="img-fluid rounded-circle mb-3" style="width: 150px; height: 150px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded-circle mx-auto mb-3" style="width: 150px; height: 150px;">
                                        <i class="fas fa-user fa-4x"></i>
                                    </div>
                                }
                                <input type="file" class="form-control" name="photoFile" accept="image/*" />
                                <small class="text-muted">Leave empty to keep current photo</small>
                            </div>
                        </div>

                        <div class="card bg-light">
                            <div class="card-body text-center">
                                <h6 class="mb-3">Resume (PDF)</h6>
                                @if (!string.IsNullOrEmpty(Model.ResumePath))
                                {
                                    <a href="@Model.ResumePath" target="_blank" class="btn btn-sm btn-success mb-3">
                                        <i class="fas fa-file-pdf me-2"></i>View Current Resume
                                    </a>
                                }
                                <input type="file" class="form-control" name="resumeFile" accept=".pdf" />
                                <small class="text-muted">Upload PDF file only</small>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="text-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}